{
    "type": "module",
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@types/fs-extra": "^11.0.4",
        "@types/node": "^24.12.4",
        "@types/prompts": "^2.4.9",
        "@typescript-eslint/eslint-plugin": "^8.59.4",
        "@typescript-eslint/parser": "^8.59.4",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-json": "^4.0.1",
        "eslint-plugin-prettier": "^5.1.3",
        "fs-extra": "^11.2.0",
        "fvtt-types": "npm:@league-of-foundry-developers/foundry-vtt-types@^13.346.0-beta.20250812191140",
        "globals": "^17.6.0",
        "handlebars": "^4.7.7",
        "prettier": "^3.2.5",
        "prompts": "^2.4.2",
        "sass": "^1.83.1",
        "socket.io": "^4.6.2",
        "socket.io-client": "^4.6.2",
        "tsx": "^4.7.2",
        "typescript": "^6.0.3",
        "vite": "^7.0.0",
        "vite-plugin-checker": "^0.6.4",
        "vite-plugin-static-copy": "^3.1.0",
        "vite-tsconfig-paths": "^4.3.2",
        "yargs": "^17.7.2"
    },
    "dependencies": {
        "@codemirror/autocomplete": "^6.18.4",
        "@codemirror/lang-json": "^6.0.1",
        "codemirror": "^6.0.1",
        "luxon": "^3.5.0",
        "minisearch": "^7.1.1",
        "nouislider": "^15.8.1",
        "remeda": "^2.19.0",
        "sortablejs": "^1.15.6",
        "uuid": "^11.0.3"
    },
    "scripts": {
        "build": "npm run clean && vite build",
        "clean": "tsx ./build/clean.ts",
        "watch": "npm run clean && vite build --watch --mode development",
        "hot": "vite serve",
        "link": "tsx ./build/link-foundry.ts",
        "lint": "npm run lint:ts && npm run && npm run prettier:scss",
        "lint:ts": "eslint ./build ./src --ext .ts",
        "prettier:scss": "prettier --check src/styles",
        "lint:json": "eslint ./static --ext .json --plugin json --rule \"json/*: error\" --rule \"linebreak-style: error\"",
        "lint:fix": "eslint ./build ./src --ext .ts --fix && prettier --write src/styles"
    }
}
