
<div class="entity-item">
<div class="flex-item vertical">
    <div class="{{#when change.value "gte" 0}}positive{{else}}negative{{/when}}" id="log-change">
        {{#when change.value "gte" 0}}
            Added
        {{/when}}
        {{#when change.value "lt" 0}}
            Subtracted
        {{/when}}
        {{change.value}}.
    </div>
    <div id="log-reason">
        {{#if change.reason}}
            Reason:
            {{change.reason}}.
        {{/if}}
    </div>
</div>
<div class="flex-item vertical" id="date-time">
    <div id="log-date">{{dateTime.date}}</div>
    <div id="log-time">{{dateTime.time}}</div>
</div>
</div>